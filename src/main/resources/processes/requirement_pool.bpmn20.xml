<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:flowable="http://flowable.org/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://byd.com/bpmn">
  <process id="requirement_pool" name="需求池流程" isExecutable="true">
    <startEvent id="start" name="需求发起"/>
    <userTask id="draft" name="草稿"/>
    <sequenceFlow id="flow_start_draft" sourceRef="start" targetRef="draft"/>
    <!-- draft 出来的网关 -->
    <exclusiveGateway id="draftGateway" name="草稿网关"/>
    <sequenceFlow id="flow_draft_gateway" sourceRef="draft" targetRef="draftGateway"/>
    <sequenceFlow id="flow_draftgw_approval" sourceRef="draftGateway" targetRef="approval">
      <conditionExpression xsi:type="tFormalExpression">${action == 'submit'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_draftgw_default" sourceRef="draftGateway" targetRef="draft"/>
    <userTask id="approval" name="审批" flowable:candidateGroups="manager"/>
    <exclusiveGateway id="approvalGateway" name="审批判断"/>
    <sequenceFlow id="flow_approval_gateway" sourceRef="approval" targetRef="approvalGateway"/>
    <sequenceFlow id="flow_gateway_review" sourceRef="approvalGateway" targetRef="review">
      <conditionExpression xsi:type="tFormalExpression">${action == 'approve'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_gateway_draft" sourceRef="approvalGateway" targetRef="draft">
      <conditionExpression xsi:type="tFormalExpression">${action == 'reject'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_gateway_default" sourceRef="approvalGateway" targetRef="draft"/>
    <userTask id="review" name="评审" flowable:candidateGroups="reviewer"/>
    <exclusiveGateway id="reviewGateway" name="评审判断"/>
    <sequenceFlow id="flow_review_gateway" sourceRef="review" targetRef="reviewGateway"/>
    <sequenceFlow id="flow_gateway_acceptance" sourceRef="reviewGateway" targetRef="acceptance">
      <conditionExpression xsi:type="tFormalExpression">${action == 'review_pass'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_gateway_draft2" sourceRef="reviewGateway" targetRef="draft">
      <conditionExpression xsi:type="tFormalExpression">${action == 'review_reject'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_reviewgw_default" sourceRef="reviewGateway" targetRef="draft"/>
    <userTask id="acceptance" name="验收" flowable:candidateGroups="acceptor"/>
    <exclusiveGateway id="acceptanceGateway" name="验收判断"/>
    <sequenceFlow id="flow_acceptance_gateway" sourceRef="acceptance" targetRef="acceptanceGateway"/>
    <sequenceFlow id="flow_gateway_end" sourceRef="acceptanceGateway" targetRef="end">
      <conditionExpression xsi:type="tFormalExpression">${action == 'accept'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_acceptgw_default" sourceRef="acceptanceGateway" targetRef="draft"/>
    <endEvent id="end" name="流程结束"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_requirement_pool">
    <bpmndi:BPMNPlane id="BPMNPlane_requirement_pool" bpmnElement="requirement_pool">
      <bpmndi:BPMNShape id="shape_start" bpmnElement="start">
        <omgdc:Bounds x="180" y="30" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="188" y="70" width="20" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_draft" bpmnElement="draft">
        <omgdc:Bounds x="148" y="120" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_draftGateway" bpmnElement="draftGateway">
        <omgdc:Bounds x="173" y="230" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_approval" bpmnElement="approval">
        <omgdc:Bounds x="148" y="320" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_approvalGateway" bpmnElement="approvalGateway">
        <omgdc:Bounds x="173" y="430" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_review" bpmnElement="review">
        <omgdc:Bounds x="148" y="520" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_reviewGateway" bpmnElement="reviewGateway">
        <omgdc:Bounds x="173" y="630" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_acceptance" bpmnElement="acceptance">
        <omgdc:Bounds x="148" y="720" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end" bpmnElement="end">
        <omgdc:Bounds x="180" y="840" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="188" y="880" width="20" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge_start_draft" bpmnElement="flow_start_draft">
        <omgdi:waypoint x="198" y="66"/>
        <omgdi:waypoint x="198" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_draft_gateway" bpmnElement="flow_draft_gateway">
        <omgdi:waypoint x="198" y="200"/>
        <omgdi:waypoint x="198" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_draftgw_approval" bpmnElement="flow_draftgw_approval">
        <omgdi:waypoint x="198" y="280"/>
        <omgdi:waypoint x="198" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_draftgw_default" bpmnElement="flow_draftgw_default">
        <omgdi:waypoint x="173" y="255"/>
        <omgdi:waypoint x="60" y="255"/>
        <omgdi:waypoint x="60" y="160"/>
        <omgdi:waypoint x="148" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_approval_gateway" bpmnElement="flow_approval_gateway">
        <omgdi:waypoint x="198" y="400"/>
        <omgdi:waypoint x="198" y="430"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_gateway_review" bpmnElement="flow_gateway_review">
        <omgdi:waypoint x="198" y="480"/>
        <omgdi:waypoint x="198" y="520"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_gateway_draft" bpmnElement="flow_gateway_draft">
        <omgdi:waypoint x="173" y="455"/>
        <omgdi:waypoint x="30" y="455"/>
        <omgdi:waypoint x="30" y="160"/>
        <omgdi:waypoint x="148" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_review_gateway" bpmnElement="flow_review_gateway">
        <omgdi:waypoint x="198" y="600"/>
        <omgdi:waypoint x="198" y="630"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_gateway_acceptance" bpmnElement="flow_gateway_acceptance">
        <omgdi:waypoint x="198" y="680"/>
        <omgdi:waypoint x="198" y="720"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_gateway_draft2" bpmnElement="flow_gateway_draft2">
        <omgdi:waypoint x="173" y="655"/>
        <omgdi:waypoint x="15" y="655"/>
        <omgdi:waypoint x="15" y="160"/>
        <omgdi:waypoint x="148" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_acceptance_end" bpmnElement="flow_acceptance_end">
        <omgdi:waypoint x="198" y="800"/>
        <omgdi:waypoint x="198" y="840"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
